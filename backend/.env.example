# OfferPilot 后端环境变量示例
# 复制为 .env 后按需修改。所有项都有合理默认值，可直接留空运行（离线规则模式）。

# 数据库连接串。默认使用项目目录下的 SQLite 文件，零配置即可运行。
# 切换到 PostgreSQL 示例：postgresql+psycopg://user:pass@localhost:5432/offerpilot
DATABASE_URL=sqlite:///./offerpilot.db

# 解析协议：none / openai / anthropic
# 这里选择的是“API 协议”，不是必须用它们家的模型。
#   - openai    ：对接任何 OpenAI 兼容服务（官方、Azure OpenAI、DeepSeek、Moonshot、OpenRouter、本地 vLLM/Ollama 等）
#   - anthropic ：对接 Anthropic 官方或其兼容网关
#   - none      ：完全使用内置规则解析，无需任何 Key（推荐先用此模式跑通闭环）
LLM_PROVIDER=none

# API Key（对接的服务需要鉴权时填写；部分本地/兼容服务无需 Key 可留空）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 自定义服务端点（base_url）。留空 = 官方默认地址；填写 = 对接兼容服务。
# 注意：很多 OpenAI 兼容服务的 base_url 需要带 /v1 后缀。
# 示例（openai 协议）：
#   DeepSeek      ：https://api.deepseek.com/v1
#   OpenRouter    ：https://openrouter.ai/api/v1
#   本地 vLLM     ：http://localhost:8001/v1
#   本地 Ollama   ：http://localhost:11434/v1
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=

# 模型名称（默认，用于对话/聚合总结/简历优化建议）。
# 对接官方时可留空走内置默认（openai: gpt-4o-mini；anthropic: claude-sonnet-4-6）。
# 对接兼容服务时【必须】显式填写该服务实际的模型名，例如：deepseek-chat、qwen2.5:7b、llama3.1 等。
# 提示：对话式 Agent 需要模型支持 function calling（如 deepseek-chat / gpt-4o-mini 等）。
LLM_MODEL=

# 按任务分流模型（留空则回退到上面的 LLM_MODEL）。典型：解析用快的小模型、对话/聚合用强的大模型。
# 例：LLM_MODEL=deepseek-v4-pro / LLM_MODEL_RESUME=deepseek-v4-flash / LLM_MODEL_JD=deepseek-v4-flash
LLM_MODEL_RESUME=
LLM_MODEL_JD=

# 联网搜索（Tavily）：让分析跟上较新的岗位方向与框架。
# 留空则不联网，Agent 仅凭已有知识作答（功能仍可用）。
# 申请地址：https://tavily.com
TAVILY_API_KEY=

# 搜索出网代理：留空则自动复用环境里的 http(s) 代理（只读取、不修改环境变量，
# 且刻意绕开可能格式有误的 ALL_PROXY/socks 变量）。如需指定可填 http://host:port
SEARCH_PROXY=

# 允许跨域的前端地址，逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
